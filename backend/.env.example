# ── RoomMatch Backend Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env.

# ── JWT Authentication ────────────────────────────────────────────────────────
# Required in production. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-strong-random-secret-here

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local default works for development. For MongoDB Atlas use:
#   MONGO_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017/
MONGO_DB_NAME=roommatch

# ── Cloudinary (photo uploads) ────────────────────────────────────────────────
# Obtain from https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Password policy (optional overrides) ─────────────────────────────────────
# Minimum password length enforced at registration and change-password.
MIN_PASSWORD_LENGTH=8

# ── CORS ─────────────────────────────────────────────────────────────────────
# The single allowed CORS origin for the frontend. Set to your deployed frontend URL in production.
FRONTEND_URL=http://localhost:3000

# ── Runtime environment ───────────────────────────────────────────────────────
# Set to "development" or "test" to allow the dev-only SECRET_KEY fallback.
# Leave unset (or set to "production") in production — SECRET_KEY is then required.
ROOMMATCH_ENV=development

# ── JWT (optional overrides) ──────────────────────────────────────────────────
# Algorithm must match what python-jose supports (HS256 recommended).
JWT_ALGORITHM=HS256
# Token lifetime in hours. Default 24h — users must re-login after expiry.
JWT_EXPIRATION_HOURS=24

# ── Rate limiting (optional — in-memory by default) ───────────────────────────
# Provide a Redis URL to persist rate limit counters across restarts/deploys.
UPSTASH_REDIS_URL=redis://your-upstash-url
UPSTASH_REDIS_REST_URL=https://your-upstash-rest-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# ── Error tracking (optional) ─────────────────────────────────────────────────
# Sentry DSN for exception tracking. Leave blank to disable.
SENTRY_DSN=
