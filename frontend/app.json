{
  "expo": {
    "name": "RoomMatch",
    "slug": "roommatch",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0E0F13"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.roommatch.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0E0F13"
      },
      "package": "com.roommatch.app"
    },
    "plugins": [
      "expo-image-picker",
      "expo-asset",
      "expo-font"
    ]
  }
}
