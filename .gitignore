# Environment variables — NEVER commit real secrets
.env
.env.local
.env.staging
*.env
# allow committed production env for frontend (no secrets, just the API URL)
!frontendv2/.env.production

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
*.so
.venv/
venv/
env/
.Python

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# Node / frontend build artifacts
node_modules/
frontendv2/dist/
frontendv2/build/
frontend/node_modules/
*.log
npm-debug.log*

# IDE / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db

# Uploads (local dev only — production uses Cloudinary)
backend/uploads/
uploads/

# Compiled bytecode caches (already listed above, belt-and-suspenders)
backend/app/__pycache__/
backend/app/**/__pycache__/
