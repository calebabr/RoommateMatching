# ── RoomMatch Frontend Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env.
# Vite exposes only variables prefixed with VITE_ to the browser bundle.

# ── Backend API base URL ──────────────────────────────────────────────────────
# Used as the default value in src/services/api.js when localStorage has no
# saved URL. Point this at your deployed backend in production.
# WARNING: this value WILL be bundled into the public JS — do NOT put secrets here.
VITE_API_BASE_URL=http://localhost:8000/api

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# Sentry DSN for frontend error tracking. Leave blank to disable.
VITE_SENTRY_DSN=
# Runtime environment tag sent to Sentry (development / staging / production)
VITE_ENV=development
